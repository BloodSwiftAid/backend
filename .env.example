ENV_MODE=local
DJANGO_SETTINGS_MODULE=core.settings
SECRET_KEY=your_secret_key_here

DATABASE_NAME=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_db_password

SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

SENTRY_DSN=your_sentry_dsn
FRONTEND_BASE_URL=http://localhost:3000
API_DOCUMENTATION_ALLOWED_EMAILS=allowed@example.com
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

VERIFICATION_OTP_TIMEOUT=3600

SESSION_COOKIE_AGE=86400
SESSION_SAVE_EVERY_REQUEST=True

CORS_ALLOWED_ORIGINS=http://localhost:3000,https://www.swiftaid.co

# ── Resend Configuration ──────────────────────────────────────────────────────
# Your Resend API Key (starts with re_...)
RESEND_API_KEY=re_your_resend_api_key

# Default From Email (e.g. "SwiftAid <onboarding@swiftaid.com>" or your custom verified domain email)
EMAIL_FROM=SwiftAid <no-reply@swiftaid.co>
